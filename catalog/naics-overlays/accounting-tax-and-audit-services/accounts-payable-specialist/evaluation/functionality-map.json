{
  "lane": "accounts-payable-specialist",
  "description": "Specialist responsible for managing vendor payments and accounts payable processes",
  "functional_areas": [
    {
      "area": "Invoice Processing",
      "functions": [
        "Receive and validate vendor invoices",
        "Match invoices to purchase orders and delivery receipts",
        "Enter invoices into accounting systems",
        "Route invoices for approval",
        "Process payments according to terms"
      ]
    },
    {
      "area": "Account Reconciliation",
      "functions": [
        "Reconcile vendor statements with internal records",
        "Identify and resolve discrepancies",
        "Maintain accurate account balances",
        "Prepare reconciliation reports"
      ]
    },
    {
      "area": "Compliance and Controls",
      "functions": [
        "Ensure adherence to financial policies",
        "Maintain documentation for audit readiness",
        "Conduct internal control testing",
        "Support external audits"
      ]
    },
    {
      "area": "Reporting and Analysis",
      "functions": [
        "Generate accounts payable reports",
        "Analyze payment trends",
        "Monitor cash flow implications",
        "Provide insights to management"
      ]
    }
  ],
  "dependencies": [
    "Purchase Order Management",
    "General Ledger",
    "Tax Compliance Systems"
  ]
}